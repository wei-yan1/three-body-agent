DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_DOCUMENT_EMBEDDING_MODEL=text-embedding-v2
DASHSCOPE_QUERY_EMBEDDING_MODEL=text-embedding-v2
DASHSCOPE_RERANK_MODEL=qwen3-rerank
TAVILY_API_KEY=your_optional_tavily_api_key_for_transparent_mode
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=three_body_agent
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CHAT_MEMORY_TTL_SECONDS=43200
CHAT_MEMORY_MAX_MESSAGES=20
EPISODIC_MEMORY_CAPACITY=40
EPISODIC_FORGET_THRESHOLD=0.4
EPISODIC_RECALL_BOOST=0.05
EPISODIC_MAX_IMPORTANCE=0.95
JWT_SECRET_KEY=change_this_dev_secret
JWT_EXPIRE_MINUTES=10080
TEST_CHAT_MODEL=qwen3.7-plus
PROD_CHAT_MODEL=qwen3.7-max
ROUTER_MODEL=glm-5
# Router defaults to DASHSCOPE_API_KEY and DASHSCOPE_BASE_URL.
# ROUTER_API_KEY=optional_different_router_key
# ROUTER_BASE_URL=optional_different_router_base_url
DEFAULT_CHAT_MODEL=qwen3.7-plus
REWRITE_CHAT_MODEL=qwen3.7-plus
